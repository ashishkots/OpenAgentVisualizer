# =============================================================================
# OpenAgentVisualizer — Production Environment Template
# =============================================================================
# Copy this file to .env and fill in all REQUIRED values before deployment.
# NEVER commit .env with real secrets to version control.
# =============================================================================

# =============================================================================
# REQUIRED — application will not start without these
# =============================================================================

# Django/FastAPI secret key — 64+ random characters
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_random_secret_key

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://oav:CHANGE_ME@postgres:5432/oav_production

# Redis connection string
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# Fernet encryption key for sensitive data at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_generate_fernet_key_with_cryptography_library

# =============================================================================
# JWT / Auth settings
# =============================================================================

# Access token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Database connection pool
# =============================================================================

# Number of persistent connections in the pool (default: 10)
DB_POOL_SIZE=10

# Extra connections allowed above pool size under load (default: 20)
DB_MAX_OVERFLOW=20

# Seconds to wait for a connection before raising OperationalError (default: 30)
DB_POOL_TIMEOUT=30

# Seconds before recycling a connection to avoid stale connections (default: 1800)
DB_POOL_RECYCLE=1800

# =============================================================================
# Redis connection pool
# =============================================================================

# Maximum simultaneous Redis connections (default: 50)
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# CORS / application environment
# =============================================================================

# Comma-separated list of allowed origins (no trailing slash)
# Example: https://app.example.com,https://www.example.com
CORS_ORIGINS=https://CHANGE_ME.example.com

# Application environment tag (production | staging | development)
ENV=production

# =============================================================================
# OPTIONAL — third-party integrations (leave blank to disable)
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=

# Datadog API key for APM/infrastructure metrics
# DD_API_KEY=
# DD_SITE=datadoghq.com

# Slack webhook URL for alert notifications
# SLACK_WEBHOOK_URL=

# OpenAI API key (if agent orchestration uses OpenAI models)
# OPENAI_API_KEY=

# Anthropic API key (if agent orchestration uses Claude models)
# ANTHROPIC_API_KEY=

# =============================================================================
# OPTIONAL — Unreal Engine 5 virtual world integration
# =============================================================================

# Base URL of the UE5 pixel streaming server
# UE5_STREAM_URL=wss://ue5.CHANGE_ME.example.com/stream

# Shared HMAC secret for UE5 <-> backend event signing
# UE5_WEBHOOK_SECRET=

# Maximum number of concurrent UE5 streaming sessions
# UE5_MAX_SESSIONS=10
