# Backend production Dockerfile — multi-stage build.
# Stage 1 (builder): installs Python dependencies into a virtual environment.
# Stage 2 (production): copies venv + app source, runs as non-root user.
# Target image size: ~350MB (python:3.12-slim base ~150MB + venv ~200MB).

# ---- Stage 1: dependency installation ----
FROM python:3.12-slim AS builder

WORKDIR /build

# Install build dependencies for packages that compile C extensions (asyncpg, cryptography)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

RUN python -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir --upgrade pip && \
    /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

# ---- Stage 2: production runtime ----
FROM python:3.12-slim AS production

# Install only runtime (non-build) system libraries
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN groupadd -r oav && useradd -r -g oav -d /app -s /sbin/nologin oav

WORKDIR /app

# Copy virtual environment from builder stage
COPY --from=builder /opt/venv /opt/venv

# Copy application source
COPY app/ ./app/

# Set virtualenv on PATH
ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Run as non-root
USER oav

# Health check uses stdlib urllib to avoid extra dependencies
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health')"

EXPOSE 8000

# Use gunicorn with uvicorn workers for production (graceful restarts, multiple workers)
CMD ["gunicorn", "app.main:app", \
     "-w", "4", \
     "-k", "uvicorn.workers.UvicornWorker", \
     "--bind", "0.0.0.0:8000", \
     "--access-logfile", "-", \
     "--error-logfile", "-", \
     "--timeout", "60"]
