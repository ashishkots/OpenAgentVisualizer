# Frontend production Dockerfile — multi-stage build.
# Stage 1 (deps): installs Node dependencies.
# Stage 2 (builder): runs Vite production build.
# Stage 3 (production): serves static files with nginx:alpine.
# Target image size: ~50MB (nginx:alpine ~40MB + static files ~10MB).

# ---- Stage 1: install dependencies ----
FROM node:20-alpine AS deps

WORKDIR /app

# Copy package manifests only — enables Docker layer caching for node_modules
COPY package.json package-lock.json* ./

# npm install (not npm ci) because package-lock.json may not be present per known fix
RUN npm install --production=false

# ---- Stage 2: build ----
FROM deps AS builder

WORKDIR /app

# Copy the full source tree (node_modules already in image from deps stage)
COPY . .

# Build arguments for runtime environment variables baked into the static bundle
ARG VITE_API_URL=/api
ARG VITE_WS_URL=/ws
ARG VITE_UE5_ENABLED=false
ARG VITE_UE5_SIGNALING_URL=

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_WS_URL=$VITE_WS_URL
ENV VITE_UE5_ENABLED=$VITE_UE5_ENABLED
ENV VITE_UE5_SIGNALING_URL=$VITE_UE5_SIGNALING_URL

RUN npm run build

# ---- Stage 3: production runtime (nginx) ----
FROM nginx:1.25-alpine AS production

# Create non-root user
RUN addgroup -S oav && adduser -S oav -G oav

# Copy built static files
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx SPA configuration (handles React Router client-side routing)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Allow non-root nginx to write to required directories
RUN chown -R oav:oav /usr/share/nginx/html && \
    chown -R oav:oav /var/cache/nginx && \
    chown -R oav:oav /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown oav:oav /var/run/nginx.pid

USER oav

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost:80/ || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
